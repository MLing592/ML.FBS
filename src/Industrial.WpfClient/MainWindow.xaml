<Window x:Class="Industrial.WpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Industrial.WpfClient.ViewModels"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="Industrial Client (gRPC + SignalR Demo)" Height="850" Width="1300" Background="#1E1E1E" Foreground="White">
    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <WrapPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Send START" Command="{Binding StartCommand}" Padding="10,5" Margin="0,0,5,5" Background="#FF333337" Foreground="LightGray"/>
            <Button Content="Bidi Stream (Live Teleop)" Command="{Binding LiveTeleoperationCommand}" Padding="10,5" Margin="0,0,15,5" Background="#FF333337" Foreground="LightGray"/>
            
            <Button Content="Simulate Remote Alarm (SignalR)" Command="{Binding TriggerAlarmCommand}" Padding="10,5" Background="#FF552222" Foreground="LightCoral" Margin="0,0,10,5"/>
            <Button Content="Push Log to Server (SignalR)" Command="{Binding SendLogToServerCommand}" Padding="10,5" Background="#FF225522" Foreground="LightGreen" Margin="0,0,10,5"/>

            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontWeight="Bold"/>
        </WrapPanel>

        <!-- Left Column: Split into TabControl (Top) and Teleop (Bottom) -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TabControl Grid.Row="0" Background="#2D2D30" Foreground="White" BorderBrush="#555" Margin="0,0,0,10">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="#1E1E1E"/>
                        <Setter Property="Foreground" Value="Gray"/>
                        <Setter Property="BorderBrush" Value="#555"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3D3D40"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.Resources>
                
                <!-- 第一页：高频数据实时监控 -->
                <TabItem Header="Vibration Monitoring (Server Stream)">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <WrapPanel Grid.Row="0" Margin="10" Orientation="Horizontal">
                            <Button Content="Start Server Stream (Data)" Command="{Binding StreamDataCommand}" Padding="10,5" Margin="0,0,5,0" Background="#FF333337" Foreground="LightGray"/>
                        </WrapPanel>
                        <oxy:PlotView Grid.Row="1" Model="{Binding PlotModel}" Margin="10,0,10,10" Background="#1E1E1E"/>
                    </Grid>
                </TabItem>
                
                <!-- 第二页：海量散点与SVG路径 -->
                <TabItem Header="Trajectory &amp; SVG Mapping">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <WrapPanel Grid.Row="0" Margin="10" Orientation="Horizontal">
                            <Button Content="Upload Client Stream (Trajectory)" Command="{Binding UploadBatchCommand}" Padding="10,5" Margin="0,0,5,0" Background="#FF333337" Foreground="LightGray"/>
                            <Button Content="Download SVG Path (Server Stream)" Command="{Binding DownloadSvgCommand}" Padding="10,5" Margin="0,0,5,0" Background="#FF333337" Foreground="LightGray"/>
                        </WrapPanel>
                        <oxy:PlotView Grid.Row="1" Model="{Binding TrajectoryPlotModel}" Margin="10,0,10,10" Background="#1E1E1E"/>
                    </Grid>
                </TabItem>
            </TabControl>
            
            <GroupBox Grid.Row="1" Header="Live Teleoperation Feed (gRPC Bidi Stream)" Background="#2D2D30" Foreground="White">
                <UniformGrid Columns="3" Margin="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Actual Angle:" Foreground="LightGray" FontSize="14"/>
                        <TextBlock Text="{Binding ActualAngle, StringFormat={}{0:F2}°}" FontSize="24" FontWeight="Bold" Foreground="Orange"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Actual Velocity:" Foreground="LightGray" FontSize="14"/>
                        <TextBlock Text="{Binding ActualVelocity, StringFormat={}{0:F2} mm/s}" FontSize="24" FontWeight="Bold" Foreground="LightBlue"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Status Warning:" Foreground="LightGray" FontSize="14"/>
                        <TextBlock Text="{Binding StatusWarning}" FontSize="24" FontWeight="Bold" Foreground="{Binding WarningColor}"/>
                    </StackPanel>
                </UniformGrid>
            </GroupBox>
        </Grid>

        <!-- Middle Column: gRPC Log -->
        <GroupBox Grid.Row="1" Grid.Column="1" Header="gRPC Action Logs" Foreground="White" Margin="0,0,10,0">
            <ListBox ItemsSource="{Binding GrpcMessages}" Background="#2D2D30" Foreground="LightGray" BorderBrush="#555">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Padding="2,5" TextWrapping="Wrap" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- Right Column: Status & Alarms (SignalR) -->
        <GroupBox Grid.Row="1" Grid.Column="2" Header="Real-time Events (SignalR)" Foreground="White">
            <ListBox ItemsSource="{Binding SignalRMessages}" Background="#2D2D30" BorderBrush="#555">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="LightGoldenrodYellow" Padding="2,5" TextWrapping="Wrap" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
    </Grid>
</Window>
